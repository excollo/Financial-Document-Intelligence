# =============================================================================
# AI LAYER BACKEND - ENVIRONMENT TEMPLATE
# Copy to .env and replace dummy values.
# =============================================================================

# App
APP_ENV=dev
APP_NAME=AI Python Platform
APP_VERSION=1.0.0
DEBUG=true

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console
APPLICATIONINSIGHTS_CONNECTION_STRING=

# MongoDB
MONGODB_URI=mongodb://localhost:27017/financial-doc-intelligence
MONGO_DB_NAME=financial-doc-intelligence
# Legacy alias used in a few scripts
MONGO_URI=mongodb://localhost:27017/financial-doc-intelligence

# Redis / Celery
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=["json"]
CELERY_TIMEZONE=Asia/Kolkata
CELERY_ENABLE_UTC=false
CELERY_WORKER_CONCURRENCY=1
CELERY_WORKER_MAX_TASKS_PER_CHILD=4
CELERY_WORKER_MAX_MEMORY_PER_CHILD=1200000

# Chunking / Extraction
MAX_CHUNK_SIZE=4800
CHUNK_OVERLAP=800
EMBEDDING_DIMENSION=3072
EMBEDDING_MODEL=text-embedding-3-large
EXTRACTION_EXECUTOR_MODE=thread
EXTRACTION_MAX_WORKERS=1
EXTRACTION_TOC_SCAN_MAX_PAGES=200
EXTRACTION_BATCH_PROGRESS_TIMEOUT_SECONDS=180
INGESTION_PARALLEL_BATCH=1
INGESTION_EXTRACTION_TIMEOUT_SECONDS=1800
ENABLE_MANUAL_GC=true
GC_EVERY_N_BATCHES=2
GC_MIN_LARGE_OBJECT_MB=100

# LLM / AI APIs
OPENAI_API_KEY=sk-your-openai-key
SUMMARY_MODEL=gpt-4.1-mini
GPT_MODEL=gpt-4o-mini
PINECONE_API_KEY=pcsk-your-pinecone-key
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX=your-index-name
PINECONE_INDEX_HOST=https://your-index-host.pinecone.io
COHERE_API_KEY=your-cohere-key
PERPLEXITY_API_KEY=your-perplexity-key
GEMINI_API_KEY=your-gemini-key
SERPER_API_KEY=your-serper-key

# Internal Node <-> Python auth
INTERNAL_SECRET=replace-with-shared-internal-secret
NODE_BACKEND_URL=http://localhost:5000

# Azure Blob Storage
AZURE_BLOB_ACCOUNT_NAME=your-storage-account
AZURE_BLOB_ACCOUNT_KEY=your-storage-account-key
AZURE_BLOB_CONTAINER_NAME=drhp-files
AZURE_BLOB_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-storage-account;AccountKey=your-storage-account-key;EndpointSuffix=core.windows.net

# Optional test helper scripts
AI_PLATFORM_URL=http://localhost:8000
