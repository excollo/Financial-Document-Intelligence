# =============================================================================
# NODE BACKEND - ENVIRONMENT TEMPLATE
# Copy to .env and replace dummy values.
# =============================================================================

# Runtime
NODE_ENV=development
PORT=5000
APP_NAME=Financial Document Intelligence

# Database
MONGODB_URI=mongodb://localhost:27017/financial-doc-intelligence
COSMOSDB_URI=mongodb://localhost:27017/financial-doc-intelligence
COSMOS_DB_NAME=financial-doc-intelligence

# Auth / JWT
JWT_SECRET=replace-with-long-random-jwt-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
INTERNAL_SECRET=replace-with-shared-internal-secret
# Internal callback signing hardening
# Production: keep signature required and Redis available for nonce replay protection.
INTERNAL_CALLBACK_SIGNING_SECRET=replace-with-shared-internal-secret
INTERNAL_CALLBACK_SIGNATURE_REQUIRED=true
INTERNAL_CALLBACK_TIMESTAMP_TOLERANCE_SECONDS=300
INTERNAL_CALLBACK_NONCE_TTL_SECONDS=300
# Optional emergency availability mode: allows in-memory nonce replay cache in production
# when Redis nonce store is unavailable. Keep false for strict multi-instance security.
INTERNAL_CALLBACK_ALLOW_IN_MEMORY_NONCE_FALLBACK_PROD=false

# Microsoft OAuth
CLIENT_ID=your-microsoft-client-id
CLIENT_SECRET=your-microsoft-client-secret
REDIRECT_URI=http://localhost:5000/api/auth/callback

# URLs
FRONTEND_URL=http://localhost:8080
PYTHON_API_URL=http://localhost:8000
APP_URL=http://localhost:8080

# Azure Blob Storage
AZURE_BLOB_ACCOUNT_NAME=your-storage-account
AZURE_BLOB_ACCOUNT_KEY=your-storage-account-key
AZURE_BLOB_CONTAINER_NAME=drhp-files
AZURE_BLOB_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-storage-account;AccountKey=your-storage-account-key;EndpointSuffix=core.windows.net
AZURE_BLOB_MAX_FILE_SIZE_MB=100

# Optional legacy Azure storage keys checked in health service
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_NAME=

# Redis / cache
REDIS_URL=redis://localhost:6379
# REQUIRED in production for internal callback nonce replay protection.

# Email / Brevo
BREVO_API_KEY=your-brevo-api-key
BREVO_FROM_EMAIL=no-reply@example.com
ADMIN_EMAIL=admin@example.com
# Comma-separated alert recipients for system health failures (only @excollo.com allowed)
HEALTH_ALERT_RECIPIENTS=sonuv@excollo.com,development@excollo.com,chinmaygupta@excollo.com
# Health alert emails are production-only by default.
# Set true in non-production only if you explicitly want alert emails.
HEALTH_ALERTS_ENABLED=false

# Optional SMTP (used in auth password reset flow)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=your-smtp-user@example.com

# Optional PDF export provider
PDFCO_API_KEY=your-pdfco-key

# Optional infra toggle
USE_KEYVAULT=false

# Realtime compatibility bridge for legacy clients.
# For security, this is ignored in production.
REALTIME_GLOBAL_BROADCAST_COMPAT=false

# Admission control strict mode.
# Keep true in production; set false for local debugging to avoid 429s from stale telemetry.
QUEUE_ADMISSION_STRICT=false

# Stale job self-healing reaper (recommended for all environments)
STALE_JOB_REAPER_ENABLED=true
STALE_JOB_REAPER_INTERVAL_MS=60000
STALE_JOB_QUEUED_TIMEOUT_MS=600000
STALE_JOB_PROCESSING_TIMEOUT_MS=2700000
STALE_LOCK_GRACE_MS=60000

# Optional: migrateDatasetsToNewCluster.ts (never commit real URIs with passwords)
# MIGRATION_SOURCE_URI=mongodb://user:password@host:10255/db?ssl=true&...
# MIGRATION_TARGET_BASE_URI=mongodb+srv://user:password@cluster/
# MIGRATION_SOURCE_DB=financial-doc-intelligence
# MIGRATION_TARGET_DB_MAIN=finanacialDocIntelligence
# MIGRATION_TARGET_DB_DEVELOP=financialDocIntellingence-develop
# MIGRATION_BATCH_SIZE=500
# MIGRATION_COPY_INDEXES=true
